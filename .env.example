# Dynasty Agent — Environment Variables Example
# Copy this file to .env and fill in your values.

# Email credentials
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
RECIPIENT_EMAIL=recipient@example.com

# Google Sheets ID (the long ID from your sheet URL)
GSHEET_ID=your_google_sheet_id

# Google Sheets tab GIDs (found in the sheet URL as ?gid=...)
ROSTER_GID=0
AVAILABLE_GID=your_available_tab_gid
DD_RANK_GID=your_dd_rank_tab_gid
BP_RANK_GID=your_bp_rank_tab_gid
TOP500_GID=your_top500_tab_gid

# Tab containing drafted player names in Column E
DRAFTED_GID=846361319

# Scheduling flags
IS_SCHEDULED=0
FORCE_RUN=0

# Run mode (daily, weekly, spring_training_daily, etc.)
RUN_MODE=daily

# Twitter / X API bearer token (optional, for social signal)
TWITTER_BEARER_TOKEN=
