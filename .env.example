# Dynasty Agent — Environment Variables Example
# Copy this file to .env and fill in your values.

# Email credentials
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
RECIPIENT_EMAIL=recipient@example.com

# Google Sheets ID (the long ID from your sheet URL)
GSHEET_ID=your_google_sheet_id

# Google Sheets tab GIDs (found in the sheet URL as ?gid=...)
ROSTER_GID=0
AVAILABLE_GID=your_available_tab_gid
DD_RANK_GID=your_dd_rank_tab_gid
BP_RANK_GID=your_bp_rank_tab_gid
TOP500_GID=your_top500_tab_gid

# Tab containing drafted player names in Column E
DRAFTED_GID=846361319

# Google Sheets API — Service Account credentials (recommended for private sheets)
# Paste the entire contents of your service account JSON key file as a single-line
# string value here.  If this variable is set the agent uses the Sheets API
# (works with private sheets).  If it is left empty the agent falls back to the
# public CSV-export URL (only works when the sheet is shared with "anyone with
# the link").
#
# Steps to create a service account key:
#   1. Go to https://console.cloud.google.com/ and open (or create) a project.
#   2. Enable the "Google Sheets API" and "Google Drive API" for the project.
#   3. Create a Service Account under IAM & Admin → Service Accounts.
#   4. Generate a JSON key for the service account and download the file.
#   5. Share your Google Sheet with the service account email address
#      (e.g. my-agent@my-project.iam.gserviceaccount.com) with at least
#      "Viewer" access.
#   6. Paste the entire JSON key file content (one line) as the value below,
#      or store it as a GitHub secret named GOOGLE_SHEETS_CREDENTIALS.
GOOGLE_SHEETS_CREDENTIALS=

# Scheduling flags
IS_SCHEDULED=0
FORCE_RUN=0

# Run mode (daily, weekly, spring_training_daily, etc.)
RUN_MODE=daily

# Twitter / X API bearer token (optional, for social signal)
TWITTER_BEARER_TOKEN=
