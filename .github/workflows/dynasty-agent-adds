name: Dynasty Agent (Adds Build)

on:
  schedule:
    # Run every 30 minutes; python also gates by America/Chicago window
    - cron: "*/30 * * * *"
  workflow_dispatch:

concurrency:
  group: dynasty-agent-adds
  cancel-in-progress: false

permissions:
  contents: write

jobs:
  run-adds:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          ref: main
          fetch-depth: 0
          persist-credentials: true

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt

      - name: Run adds_build (Chicago gated in code)
        env:
          EMAIL_ADDRESS: ${{ secrets.EMAIL_ADDRESS }}
          EMAIL_PASSWORD: ${{ secrets.EMAIL_PASSWORD }}
          RECIPIENT_EMAIL: ${{ secrets.RECIPIENT_EMAIL }}

          GSHEET_ID: ${{ secrets.GSHEET_ID }}
          ROSTER_GID: ${{ secrets.ROSTER_GID }}
          AVAILABLE_GID: ${{ secrets.AVAILABLE_GID }}
          DD_RANK_GID: ${{ secrets.DD_RANK_GID }}
          BP_RANK_GID: ${{ secrets.BP_RANK_GID }}
          TOP500_GID: ${{ secrets.TOP500_GID }}

          RUN_MODE: adds_build
          IS_SCHEDULED: "1"
        run: |
          timeout 6h45m python -u agent.py

      - name: Commit state/logs (if changed)
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"

          mkdir -p state
          touch state/state.json state/weekly_official.jsonl state/weekly_reports.jsonl state/adds_cache.json

          git add state/state.json state/weekly_official.jsonl state/weekly_reports.jsonl state/adds_cache.json || true
          git diff --cached --quiet && echo "No state changes to commit" && exit 0

          git commit -m "Update agent state (adds build)"
          git fetch origin main
          git rebase origin/main
          git push origin HEAD:main
